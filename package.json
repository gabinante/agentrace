{
  "name": "agentic-flow-replay",
  "version": "0.1.0",
  "description": "Turn agent logs into interactive flow visualizations. Framework-agnostic log parsing with React replay components.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./components": {
      "types": "./dist/components/index.d.ts",
      "import": "./dist/components/index.js"
    },
    "./parsers": {
      "types": "./dist/parsers/index.d.ts",
      "import": "./dist/parsers/index.js"
    }
  },
  "scripts": {
    "dev": "vite demo",
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist",
    "src"
  ],
  "keywords": [
    "agent",
    "flow",
    "replay",
    "visualization",
    "logs",
    "debugging",
    "ai-agents",
    "observability"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/gabinante/agentic-flow-replay"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "eslint": "^9.0.0",
    "primereact": "^10.5.0",
    "primeicons": "^7.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "@vitejs/plugin-react": "^4.0.0"
  }
}
